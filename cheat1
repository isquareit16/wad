<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Admin Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    display:flex;
}

/* Sidebar */
.sidebar{
    width:220px;
    height:100vh;
    background:#222;
    color:white;
    padding-top:20px;
}

.sidebar h2{
    text-align:center;
    margin-bottom:30px;
}

.sidebar a{
    display:block;
    color:white;
    padding:15px 20px;
    text-decoration:none;
    border-bottom:1px solid #444;
}

.sidebar a:hover{
    background:#0d6efd;
}

/* Main Content */
.content{
    flex:1;
    padding:20px;
    background:#f4f4f4;
}

/* Hide all sections */
.section{
    display:none;
}

/* Show selected section */
.section:target{
    display:block;
}

/* Default Home Section */
#home{
    display:block;
}

/* Cards */
.cards{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
    margin-top:20px;
}

.card{
    background:white;
    padding:20px;
    width:200px;
    border-radius:10px;
    box-shadow:0 3px 8px rgba(0,0,0,0.1);
    text-align:center;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:20px;
    background:white;
}

table, th, td{
    border:1px solid #ccc;
}

th, td{
    padding:12px;
    text-align:center;
}

th{
    background:#0d6efd;
    color:white;
}
</style>

</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <h2>Dashboard</h2>
    <a href="#home">Home</a>
    <a href="#students">Students</a>
    <a href="#courses">Courses</a>
    <a href="#exams">Exams</a>
</div>

<!-- Main Content -->
<div class="content">

    <!-- Home -->
    <div id="home" class="section">
        <h1>Home Dashboard</h1>

        <div class="cards">
            <div class="card">
                <h3>Total Students</h3>
                <p>1200</p>
            </div>

            <div class="card">
                <h3>Total Courses</h3>
                <p>35</p>
            </div>

            <div class="card">
                <h3>Upcoming Exams</h3>
                <p>12</p>
            </div>
        </div>
    </div>

    <!-- Students -->
    <div id="students" class="section">
        <h1>Students Section</h1>

        <table>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Course</th>
            </tr>
            <tr>
                <td>101</td>
                <td>Rahul</td>
                <td>BCA</td>
            </tr>
            <tr>
                <td>102</td>
                <td>Priya</td>
                <td>MCA</td>
            </tr>
        </table>
    </div>

    <!-- Courses -->
    <div id="courses" class="section">
        <h1>Courses Section</h1>

        <ul style="margin-top:20px; line-height:2;">
            <li>BCA</li>
            <li>MCA</li>
            <li>BSc IT</li>
            <li>MBA</li>
        </ul>
    </div>

    <!-- Exams -->
    <div id="exams" class="section">
        <h1>Exam Section</h1>

        <table>
            <tr>
                <th>Exam Name</th>
                <th>Date</th>
            </tr>
            <tr>
                <td>Semester 1</td>
                <td>10 May 2026</td>
            </tr>
            <tr>
                <td>Semester 2</td>
                <td>25 May 2026</td>
            </tr>
        </table>
    </div>

</div>

</body>
</html>
